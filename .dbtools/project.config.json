{
  "project" : "project-hdi",
  "sqlcl" : {
    "connectionName" : "hdi-test",
    "autoConnect" : false,
    "version" : "26.1.0.0"
  },
  "schemas" : [ "RMAIS", "RMAIS_DEV" ],
  "lastReleaseVersion" : "",
  "export" : {

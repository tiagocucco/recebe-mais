      "force" : true,
      "partitioning" : false,
      "segmentAttributes" : false,
      "sizeByteKeyword" : true,
      "sqlterminator" : true,
      "storage" : false,
      "tablespace" : false
    },
    "apex" : {
      "exptype" : [ "READABLE_YAML", "APPLICATION_SOURCE" ],
      "expAclAssignments" : false,
      "expComments" : true,
      "skipExportDate" : false,
      "expirNotif" : false,
      "expOriginalIds" : true,
      "expSavedReports" : true,
      "expPubReports" : true,
      "expSubscriptions" : true,
      "expSupportingObjects" : "Y",
      "expTranslations" : true,
      "auditType" : "NULL"
    }
  },
  "git" : {
    "protectedBranches" : [ "main", "master" ],
    "defaultBranch" : "main"
  },
  "stage" : {
    "excludeObjects" : [ "ALL.user" ],
    "generatedFormat" : "liquibase",
    "softObjectIsolation" : "change",
    "substituteSchemas" : false
  }
}